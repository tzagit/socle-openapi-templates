{
  "name": "@estreem/openapi-socle",
  "version": "0.1.0",
  "type": "module",
  "description": "Socle de templating YAML pour OpenAPI (exposed | called | events) — build, import, CLI.",
  "bin": {
    "openapi-socle": "bin/openapi-socle.mjs"
  },
  "files": [
    "bin",
    "tools",
    "templates",
    "functions",
    "redocly.yaml",
    ".spectral.yaml",
    "SPEC.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "test": "node --test",
    "build": "node tools/build.mjs",
    "build:one": "node tools/build.mjs --project",
    "import": "node tools/import.mjs",
    "lint": "npm run build && redocly lint build/*.openapi.yaml",
    "spectral": "npm run build && spectral lint \"build/*.openapi.yaml\" --ruleset .spectral.yaml --fail-severity=error",
    "check:dictionary": "node tools/check-dictionary.mjs",
    "check:regression": "node tools/check-regression.mjs",
    "release:notes": "node tools/release-notes.mjs",
    "golden:update": "rm -f build/*.openapi.yaml && node tools/build.mjs && rm -f golden/*.openapi.yaml && cp build/*.openapi.yaml golden/",
    "verify": "npm run check:dictionary && npm run lint && npm run spectral && npm run check:regression"
  },
  "dependencies": {
    "js-yaml": "^4.1.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@redocly/cli": "^1.25.0",
    "@stoplight/spectral-cli": "^6.16.1"
  },
  "publishConfig": {
    "@estreem:registry": "https://artifactory.example.com/artifactory/api/npm/npm-local/"
  }
}
